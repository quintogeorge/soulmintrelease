    "@solana/spl-token": "0.4.13",
    "@solana/web3.js": "1.95.8",
    "firebase-admin": "^13.4.0",
    "firebase-functions": "^6.0.1",
    "pinata": "^2.5.0",
    "utf-8-validate": "^5.0.10"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
